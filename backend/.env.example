# HTTP server port
PORT=8080

# Postgres connection string
DATABASE_URL=postgres://sesfikile:sesfikile_dev@localhost:5432/sesfikile?sslmode=disable

# HS256 secret used to sign/verify auth JWTs. The value below is a dev-only
# default baked into internal/config — override it with a real secret in any
# shared or production environment.
JWT_SECRET=dev-only-insecure-secret-change-me

# Migrations (backend/migrations/*.sql, golang-migrate format) run
# automatically on server startup (cmd/server) and before seeding
# (cmd/seed) whenever the database is reachable. To run them by hand instead
# (e.g. with the golang-migrate CLI, `go install github.com/golang-migrate/migrate/v4/cmd/migrate@latest`):
#   migrate -database "$DATABASE_URL" -path backend/migrations up
#   migrate -database "$DATABASE_URL" -path backend/migrations down
#
# Seed dev data (1 owner, 2 vehicles, 2 drivers, 2 commuters) with:
#   go run ./cmd/seed
